# Database (provided automatically by Railway PostgreSQL plugin)
DATABASE_URL=postgresql://user:password@host:5432/norahairline

# Server
NODE_ENV=production
PORT=5000

# JWT (generate a strong random secret)
JWT_SECRET=your-strong-jwt-secret-here

# Frontend URL (leave empty — backend serves the frontend)
# FRONTEND_URL=https://your-app.railway.app

# OneSignal push notifications (OneSignal dashboard → Settings → Keys & IDs)
ONESIGNAL_APP_ID=your-onesignal-app-id-here
ONESIGNAL_REST_API_KEY=your-onesignal-rest-api-key-here
